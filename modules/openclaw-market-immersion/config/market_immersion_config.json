    "max_pages": 99,
    "crawl_delay_seconds": 2,
    "timeout": 120,
    "analysis": {
      "enabled": true,
      "mode": "openclaw",
      "agent": "daily-writer",
      "model": "openai-codex/gpt-5.5",
      "thinking": "high",
      "timeout": 300,
      "parallelism": 1,
      "combined_call": true,
      "detailed_max_page_no": 4,
      "prompt_template_path": "~/.openclaw/private-prompts/people_daily/article_analysis_v1.md",
      "required_prompt_id": "people_daily_article_combined_v1_2026-05-06",
      "full_analysis": {
        "prompt_template_path": "~/.openclaw/private-prompts/people_daily/article_full_analysis_v1.md",
        "required_prompt_id": "people_daily_full_analysis_v1_2026-05-06"
      },
      "structured_groups": {
        "prompt_template_path": "~/.openclaw/private-prompts/people_daily/article_structured_groups_v1.md",
        "required_prompt_id": "people_daily_structured_groups_v1_2026-05-06"
      },
      "overview": {
        "enabled": true,
        "prompt_template_path": "~/.openclaw/private-prompts/people_daily/issue_overview_v1.md",
        "required_prompt_id": "people_daily_overview_v1_2026-05-06",
        "allow_deterministic_fallback": false
      },
      "allow_deterministic_fallback": false
    },
    "notion": {
      "enabled": false,
      "secrets_env": "~/.openclaw/secrets/notion.env",
      "token_env": "NOTION_TOKEN",
      "finance_page_id": "",
      "people_daily_page_id": "",
      "timeout": 120,
      "people_daily_page_id_env": "NOTION_PEOPLE_DAILY_PAGE_ID",
      "finance_page_id_env": "NOTION_FINANCE_PAGE_ID"
    }
  },
  "openclaw_summary": {
    "enabled": true,
    "required": true,
    "summarize_smoke": true,
    "agent": "daily-writer",
    "model": "openai-codex/gpt-5.5",
    "thinking": "high",
    "timeout": 300,
    "retries": 3,
    "max_item_chars": 0,
    "max_message_chars": 50000,
    "input_mode": "full_file",
    "allow_degraded_fallback": false
  },
  "raw_flow_classification": {
    "enabled": false,
    "agent": "ark-review",
    "model": "volcengine-plan/glm-5.1",
    "thinking": "low",
    "timeout": 180,
    "max_items": 260,
    "shard_size": 60,
    "parallelism": 3
  },
  "raw_flow_quality_check": {
    "enabled": true,
    "mode": "large_context",
    "agent": "ark-review",
    "model": "kimi-k2.6",
    "thinking": "low",
    "timeout": 900,
    "retries": 2,
    "retry_wait": 90,
    "provider_secrets_env": "~/.openclaw/secrets/volcengine.env",
    "include_report_chars": 40000,
    "max_items": 0,
    "max_item_chars": 300,
    "max_message_chars": 50000,
    "role": "review_only_gpt_decides",
    "gpt_review_decision_enabled": true,
    "gpt_review_agent": "daily-writer",
    "gpt_review_model": "openai-codex/gpt-5.5",
    "gpt_review_thinking": "high"
  },
  "pipeline": {
    "collection_parallelism": 4,
    "allow_degraded_publication": false
  },
