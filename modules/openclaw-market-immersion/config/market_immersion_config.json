  "runs": {
    "smoke": {
      "label": "连通性测试",
      "queries": [
        {
          "id": "smoke_market",
          "skill": "mx-search",
          "query": "今日A股市场重要信息 测试查询"
        }
      ]
    },
    "morning": {
      "label": "盘前信息浸泡",
      "queries": [
        {
          "id": "market_overview",
          "skill": "mx-search",
          "query": "今日A股市场盘前重要信息 新闻 公告 政策 研报 产业事件 汇总"
        },
        {
          "id": "macro_policy",
          "skill": "mx-search",
          "query": "今日影响A股的宏观政策 监管政策 产业政策 重要会议 消息"
        },
        {
          "id": "industry_themes",
          "skill": "mx-search",
          "query": "今日A股热门行业 热门主题 板块催化 新闻 研报 政策"
        },
        {
          "id": "announcements",
          "skill": "mx-search",
          "query": "今日A股上市公司重要公告 业绩 重大合同 并购 重组 减持 增持 风险提示"
        },
        {
          "id": "research_views",
          "skill": "mx-search",
          "query": "今日A股机构研报 评级调整 行业观点 公司观点 汇总"
        }
      ]
    },
    "midday": {
      "label": "午间信息浸泡",
      "queries": [
        {
          "id": "midday_market",
          "skill": "mx-search",
          "query": "今日A股午间市场异动 板块异动 个股异动 资金关注 新闻原因"
        },
        {
          "id": "midday_topics",
          "skill": "mx-search",
          "query": "今日上午A股反复出现的市场主题 新闻 产业政策 个股事件"
        },
        {
          "id": "midday_announcements",
          "skill": "mx-search",
          "query": "今日上午A股重要公告 公司事件 风险提示"
        }
      ]
    },
    "close": {
      "label": "收盘信息浸泡",
      "queries": [
        {
          "id": "close_review",
          "skill": "mx-search",
          "query": "今日A股收盘复盘 板块涨跌 个股异动 成交量 资金流 新闻原因"
        },
        {
          "id": "after_close_announcements",
          "skill": "mx-search",
          "query": "今日收盘后A股上市公司重要公告 业绩 重大事项 风险提示"
        },
        {
          "id": "after_close_research",
          "skill": "mx-search",
          "query": "今日收盘后机构研报 行业观点 公司观点 评级调整"
        },
        {
          "id": "daily_repeated_terms",
          "skill": "mx-search",
          "query": "今日A股市场高频关键词 反复出现的主题 板块 公司 新闻线索"
        }
      ]
    },
    "night": {
      "label": "夜间信息归档",
      "queries": [
        {
          "id": "overnight_watch",
          "skill": "mx-search",
