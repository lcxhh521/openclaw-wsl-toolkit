[Unit]
Description=OpenClaw People's Daily deep read
Wants=network-online.target
After=network-online.target
StartLimitIntervalSec=8h
StartLimitBurst=8

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace/market-immersion-module
ExecStart=%h/.openclaw/workspace/market-immersion-module/scripts/run_people_daily_deep_read.sh
TimeoutStartSec=21600
Restart=no
RestartSec=30min
