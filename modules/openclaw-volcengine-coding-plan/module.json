{
  "id": "volcengine-coding-plan",
  "name": "OpenClaw Volcengine Coding Plan",
  "type": "openclaw-provider-module",
  "version": "0.1.0",
  "description": "Documents the Volcengine Ark Coding Plan endpoint and OpenClaw model references.",
  "provider": "volcengine-plan",
  "default_model": "volcengine-plan/ark-code-latest",
  "base_url": "https://ark.cn-beijing.volces.com/api/coding/v3",
  "secret_file": "~/.openclaw/secrets/volcengine.env",
  "config_files": [
    "~/.openclaw/openclaw.json",
    "~/.openclaw/agents/main/agent/models.json"
  ]
}
