[Unit]
Description=OpenClaw Market Source Interface Verification
After=network-online.target openclaw-gateway.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace
ExecStart=%h/.openclaw/workspace/market-immersion-module/scripts/verify_source_interfaces.py --timeout 20 --sample-size 8
TimeoutStartSec=900
Restart=no
