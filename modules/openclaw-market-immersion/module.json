{
  "id": "market-immersion",
  "name": "OpenClaw Market Immersion",
  "type": "openclaw-job-module",
  "version": "0.1.0",
  "description": "Scheduled market information immersion collector and Notion publisher for OpenClaw.",
  "entrypoint": "scripts/run_market_immersion.sh",
  "people_daily_deep_read": "scripts/run_people_daily_deep_read.sh",
  "config": "config/market_immersion_config.json",
  "output_dir": "~/.openclaw/workspace/market-immersion",
  "phases": {
    "morning": {
      "schedule": "09:05",
      "service": "openclaw-market-immersion-morning.service",
      "timer": "openclaw-market-immersion-morning.timer"
    },
    "midday": {
      "schedule": "12:15",
      "service": "openclaw-market-immersion-midday.service",
      "timer": "openclaw-market-immersion-midday.timer"
    },
    "close": {
      "schedule": "15:20",
      "service": "openclaw-market-immersion-close.service",
      "timer": "openclaw-market-immersion-close.timer"
    },
    "night": {
      "schedule": "22:10",
      "service": "openclaw-market-immersion-night.service",
      "timer": "openclaw-market-immersion-night.timer"
    }
  },
  "publishing": {
    "notion": true,
    "telegram": true
  },
  "longform_workflows": {
    "people_daily_deep_read": {
      "entrypoint": "scripts/run_people_daily_deep_read.sh",
      "output_dir": "~/.openclaw/workspace/people-daily-deep-read",
      "notion_path": "财经政经 / 人民日报 / YYYY年MM月DD日",
      "default_detailed_pages": "01-04"
    }
  },
  "hard_requirements": {
    "complete_feed_window": true,
    "openclaw_summary": true,
    "publish_only_after_success": true
  }
}
